# Copy to .env.local and fill in real values. .env.local is gitignored.

# Zitadel OIDC — self-hosted instance base URL (the issuer/authority).
VITE_ZITADEL_AUTHORITY=http://localhost:8081

# Client ID of the Zitadel "User Agent" (SPA) app configured for PKCE.
# The app's Auth Token Type must be JWT (not Bearer) so the Spring resource
# server can verify tokens locally — see markdown/ENDPOINT.md.
VITE_ZITADEL_CLIENT_ID=REPLACE_WITH_ZITADEL_SPA_CLIENT_ID

# Base URL of the Spring Boot API.
VITE_API_BASE_URL=http://localhost:8080
