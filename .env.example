# ⚠️  INSECURE DEFAULTS — for local development only.
# Copy to .env and adjust before first `docker compose up`. Never commit the real .env file.
#
# Note: the app's own Postgres database is NOT part of this compose file -- it uses whatever
# native/existing Postgres is already running on this machine (see application.yml's DB_URL/
# DB_USERNAME/DB_PASSWORD). Set those as real environment variables when running the app; they
# have no bearing on `docker compose up` here.

# -----------------------------
# Zitadel: domain and external URL
# -----------------------------
ZITADEL_DOMAIN=localhost
# Remapped from Zitadel's own default of 8080, which collides with Spring Boot's default port.
PROXY_HTTP_PUBLISHED_PORT=8081
ZITADEL_EXTERNALPORT=8081
ZITADEL_EXTERNALSECURE=false
ZITADEL_PUBLIC_SCHEME=http

# -----------------------------
# Zitadel: security/bootstrap
# -----------------------------
# Must be exactly 32 chars for new deployments. Cannot be changed later without data loss.
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters
LOGIN_CLIENT_PAT_EXPIRATION=2099-01-01T00:00:00Z

# -----------------------------
# Zitadel: pinned image tags
# -----------------------------
ZITADEL_VERSION=v4.16.0
TRAEFIK_IMAGE=traefik:v3.7.7
POSTGRES_IMAGE=postgres:17.10-alpine

# -----------------------------
# Zitadel: proxy settings
# -----------------------------
TRAEFIK_DASHBOARD_ENABLED=false
TRAEFIK_LOG_LEVEL=INFO
TRAEFIK_ACCESSLOG_ENABLED=true

# -----------------------------
# Zitadel: its own dedicated Postgres (kept separate from the app's `db` above so Zitadel's
# internal migrations aren't coupled to the app's Flyway lifecycle)
# -----------------------------
POSTGRES_DB=zitadel
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=postgres
ZITADEL_DATABASE_POSTGRES_DSN=postgresql://postgres:postgres@zitadel-postgres:5432/zitadel?sslmode=disable

# -----------------------------
# Zitadel: access logs
# -----------------------------
ZITADEL_ACCESS_LOG_STDOUT_ENABLED=true
