<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.server.security.SecurityMapper">

    <resultMap id="authUserRowMap" type="com.example.server.security.AuthUserRow">
        <constructor>
            <idArg column="user_id" javaType="java.util.UUID" name="userId"/>
            <arg column="department_id" javaType="java.util.UUID" name="departmentId"/>
            <arg column="role_id" javaType="java.util.UUID" name="roleId"/>
            <arg column="role_name" javaType="string" name="roleName"/>
            <arg column="full_name" javaType="string" name="fullName"/>
            <arg column="email" javaType="string" name="email"/>
            <arg column="status" javaType="string" name="status"/>
        </constructor>
    </resultMap>

    <select id="findAuthUserByZitadelUserId" resultMap="authUserRowMap">
        SELECT u.user_id, u.department_id, u.role_id, r.name AS role_name, u.full_name, u.email, u.status
        FROM users u
        JOIN role r ON r.role_id = u.role_id
        WHERE u.zitadel_user_id = #{zitadelUserId}
    </select>

    <select id="findPermissionKeysByRoleId" resultType="string">
        SELECT p.key
        FROM role_permission rp
        JOIN permission p ON p.permission_id = rp.permission_id
        WHERE rp.role_id = #{roleId}
    </select>

</mapper>
