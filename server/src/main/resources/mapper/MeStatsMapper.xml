<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.server.module.project.me.MeStatsMapper">

    <resultMap id="myStatsMap" type="com.example.server.module.project.me.dto.MyStats">
        <constructor>
            <arg column="assigned_task_count" javaType="_long" name="assignedTaskCount"/>
            <arg column="completed_task_count" javaType="_long" name="completedTaskCount"/>
            <arg column="overdue_task_count" javaType="_long" name="overdueTaskCount"/>
            <arg column="in_progress_task_count" javaType="_long" name="inProgressTaskCount"/>
            <arg column="in_review_task_count" javaType="_long" name="inReviewTaskCount"/>
        </constructor>
    </resultMap>

    <select id="findStats" resultMap="myStatsMap">
        SELECT
            COUNT(*) AS assigned_task_count,
            COUNT(*) FILTER (WHERE status = 'COMPLETED') AS completed_task_count,
            COUNT(*) FILTER (WHERE status &lt;&gt; 'COMPLETED' AND due_date &lt; CURRENT_DATE) AS overdue_task_count,
            COUNT(*) FILTER (WHERE status = 'IN_PROGRESS') AS in_progress_task_count,
            COUNT(*) FILTER (WHERE status = 'IN_REVIEW') AS in_review_task_count
        FROM task
        WHERE assignee_id = #{userId}
    </select>

    <resultMap id="myTaskMap" type="com.example.server.module.project.me.dto.MyTask">
        <constructor>
            <idArg column="task_id" javaType="java.util.UUID" name="taskId"/>
            <arg column="project_id" javaType="java.util.UUID" name="projectId"/>
            <arg column="project_name" javaType="string" name="projectName"/>
            <arg column="title" javaType="string" name="title"/>
            <arg column="status" javaType="string" name="status"/>
            <arg column="due_date" javaType="java.time.LocalDate" name="dueDate"/>
        </constructor>
    </resultMap>

    <select id="findMyTasks" resultMap="myTaskMap">
        SELECT t.task_id, t.project_id, p.name AS project_name, t.title, t.status, t.due_date
        FROM task t
        JOIN project p ON p.project_id = t.project_id
        WHERE t.assignee_id = #{userId} AND t.status &lt;&gt; 'COMPLETED'
        ORDER BY t.due_date ASC NULLS LAST
        LIMIT #{limit}
    </select>

</mapper>
